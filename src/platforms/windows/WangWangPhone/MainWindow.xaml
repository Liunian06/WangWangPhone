<Window x:Class="WangWangPhone.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WangWangPhone"
        mc:Ignorable="d"
        Title="WangWangPhone" Height="800" Width="400"
        Background="{DynamicResource SystemBackgroundBrush}">
    <Window.Resources>
        <Style x:Key="SystemTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SystemTextBrush}"/>
        </Style>
    </Window.Resources>
    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Status Bar Placeholder -->
        <TextBlock Text="09:41 📶 5G 🔋" Foreground="White" HorizontalAlignment="Center" Margin="10"/>

        <!-- Widgets Area -->
        <Grid x:Name="WidgetsContainer" Grid.Row="1" Margin="20,10,20,20" VerticalAlignment="Top" Height="150">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Clock Widget (可拖拽) -->
            <Border x:Name="ClockWidgetBorder" Grid.Column="0" CornerRadius="20" Margin="0,0,5,0" Cursor="Hand"
                    MouseLeftButtonDown="Widget_MouseLeftButtonDown" MouseLeftButtonUp="Widget_MouseLeftButtonUp"
                    MouseMove="Widget_MouseMove" MouseLeave="Widget_MouseLeave">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#E0C3FC" Offset="0"/>
                        <GradientStop Color="#8EC5FC" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel VerticalAlignment="Center" Margin="15">
                    <TextBlock x:Name="DateText" Text="10月1日 星期一" Foreground="White" FontSize="12" FontWeight="Medium"/>
                    <TextBlock x:Name="TimeText" Text="09:41" Foreground="White" FontSize="40" FontWeight="Bold"/>
                    <TextBlock x:Name="ClockCityText" Text="北京" Foreground="#CCFFFFFF" FontSize="12"/>
                </StackPanel>
            </Border>

            <!-- Weather Widget (可拖拽) -->
            <Border x:Name="WeatherWidgetBorder" Grid.Column="1" CornerRadius="20" Margin="5,0,0,0" Cursor="Hand"
                    MouseLeftButtonDown="Widget_MouseLeftButtonDown" MouseLeftButtonUp="Widget_MouseLeftButtonUp"
                    MouseMove="Widget_MouseMove" MouseLeave="Widget_MouseLeave">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#4FACFE" Offset="0"/>
                        <GradientStop Color="#00F2FE" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="15">
                    <StackPanel VerticalAlignment="Top" HorizontalAlignment="Left">
                        <TextBlock x:Name="WeatherCityText" Text="北京" Foreground="White" FontSize="16" FontWeight="Bold"/>
                        <TextBlock x:Name="WeatherTempText" Text="24°" Foreground="White" FontSize="40" FontWeight="Light"/>
                    </StackPanel>
                    <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Right">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                             <TextBlock x:Name="WeatherIconText" Text="☀️" FontSize="24" Margin="0,0,5,0"/>
                             <TextBlock x:Name="WeatherDescText" Text="晴朗" Foreground="White" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="WeatherRangeText" Text="H:28° L:18°" Foreground="#CCFFFFFF" FontSize="10" HorizontalAlignment="Right"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Edit Mode Banner - 只显示完成按钮 -->
        <Border x:Name="EditModeBanner" Grid.Row="1" Margin="20,170,20,0" VerticalAlignment="Top"
                CornerRadius="12" Background="#26FFFFFF" Padding="16,10" Visibility="Collapsed" Panel.ZIndex="50">
            <Grid>
                <TextBlock x:Name="EditDoneButton" Text="完成" Foreground="#007AFF" FontSize="16" FontWeight="Bold"
                           HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand"
                           MouseDown="OnEditDoneClick"/>
            </Grid>
        </Border>

        <!-- 4x6 Draggable App Grid -->
        <Canvas x:Name="AppGridCanvas" Grid.Row="1" Margin="20,210,20,110" VerticalAlignment="Stretch"
                Background="Transparent" AllowDrop="True"
                DragOver="AppGridCanvas_DragOver" Drop="AppGridCanvas_Drop"
                SizeChanged="AppGridCanvas_SizeChanged"/>

        <!-- Settings Overlay -->
        <Border x:Name="SettingsOverlay" Grid.Row="0" Grid.RowSpan="3" Background="{DynamicResource SettingsBackgroundBrush}" Visibility="Collapsed" Panel.ZIndex="100">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Settings Header -->
                <Grid Height="60" Background="{DynamicResource HeaderBackgroundBrush}">
                    <TextBlock Text="设置" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource SystemTextBrush}"/>
                    <Button Content="返回" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15,0" Background="Transparent" BorderThickness="0" Foreground="#007AFF" Click="OnBackClick"/>
                </Grid>

                <!-- Settings Content -->
                <ScrollViewer Grid.Row="1">
                    <StackPanel Margin="15">
                        <TextBlock Text="激活与授权" FontSize="13" Foreground="#8E8E93" Margin="10,0,10,5"/>
                        <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="10" Padding="0">
                            <Button HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" Background="Transparent" BorderThickness="0" Click="OnActivationClickUI">
                                <Grid Padding="15">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="软件激活" FontSize="16" Foreground="{DynamicResource SystemTextBrush}"/>
                                        <TextBlock x:Name="ExpiryDateText" Text="有效期至: 2030-01-01" FontSize="12" Foreground="#8E8E93" Visibility="Collapsed"/>
                                    </StackPanel>
                                    <TextBlock x:Name="ActivationStatusText" Text="未激活 >" Foreground="#8E8E93" FontSize="16" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </Button>
                        </Border>

                        <TextBlock Text="外观" FontSize="13" Foreground="#8E8E93" Margin="10,20,10,5"/>
                        <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="10" Padding="0">
                            <Button HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" Background="Transparent" BorderThickness="0" Click="OnDisplaySettingsClick">
                                <Grid Padding="15">
                                    <TextBlock Text="显示设置" FontSize="16" Foreground="{DynamicResource SystemTextBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text=">" Foreground="#8E8E93" FontSize="16" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </Button>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Activation Screen -->
        <Border x:Name="ActivationOverlay" Grid.Row="0" Grid.RowSpan="3" Background="{DynamicResource SettingsBackgroundBrush}" Visibility="Collapsed" Panel.ZIndex="110">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <Grid Height="60" Background="{DynamicResource HeaderBackgroundBrush}">
                    <TextBlock Text="激活授权" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource SystemTextBrush}"/>
                    <Button Content="取消" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15,0" Background="Transparent" BorderThickness="0" Foreground="#007AFF" Click="OnActivationBackClick"/>
                </Grid>

                <StackPanel Grid.Row="1" Margin="20">
                    <TextBlock Text="机器码" FontSize="14" Foreground="#8E8E93" Margin="0,0,0,5"/>
                    <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <TextBox x:Name="MachineIdTextBox" IsReadOnly="True" BorderThickness="0" Background="Transparent" Text="WIN-ID-FETCHING..." Foreground="{DynamicResource SystemTextBrush}"/>
                    </Border>
                    <Button Content="复制机器码" Background="#34C759" Foreground="White" Padding="10" BorderThickness="0" Margin="0,0,0,20" Click="OnCopyMachineId">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <TextBlock Text="激活码" FontSize="14" Foreground="#8E8E93" Margin="0,0,0,5"/>
                    <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <TextBox x:Name="LicenseKeyTextBox" Height="100" TextWrapping="Wrap" BorderThickness="0" Background="Transparent" AcceptsReturn="True" Foreground="{DynamicResource SystemTextBrush}"/>
                    </Border>
                    <Button Content="粘贴激活码" Background="#5856D6" Foreground="White" Padding="10" BorderThickness="0" Margin="0,0,0,20" Click="OnPasteLicenseKey">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="激活" Background="#007AFF" Foreground="White" Padding="15" BorderThickness="0" Click="OnActivateSubmit">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Display Settings Overlay -->
        <Border x:Name="DisplaySettingsOverlay" Grid.Row="0" Grid.RowSpan="3" Background="{DynamicResource SettingsBackgroundBrush}" Visibility="Collapsed" Panel.ZIndex="120">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <Grid Height="60" Background="{DynamicResource HeaderBackgroundBrush}">
                    <TextBlock Text="显示设置" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource SystemTextBrush}"/>
                    <Button Content="返回" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15,0" Background="Transparent" BorderThickness="0" Foreground="#007AFF" Click="OnDisplaySettingsBackClick"/>
                </Grid>

                <ScrollViewer Grid.Row="1">
                    <StackPanel Margin="15">
                        <TextBlock Text="锁屏壁纸" FontSize="13" Foreground="#8E8E93" Margin="10,0,10,5"/>
                        <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="10">
                            <Button Background="Transparent" BorderThickness="0" Click="OnSelectLockWallpaperClick">
                                <Grid Padding="15">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="锁屏壁纸设置" FontSize="16" Foreground="{DynamicResource SystemTextBrush}"/>
                                        <TextBlock x:Name="LockWpStatusText" Text="点击从本地导入" FontSize="12" Foreground="#8E8E93"/>
                                    </StackPanel>
                                    <Border x:Name="LockWpPreview" Width="50" Height="50" HorizontalAlignment="Right" Background="#EEE" CornerRadius="5" Overflow="Hidden">
                                        <TextBlock Text="🖼️" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20"/>
                                    </Border>
                                </Grid>
                            </Button>
                        </Border>

                        <TextBlock Text="桌面壁纸" FontSize="13" Foreground="#8E8E93" Margin="10,20,10,5"/>
                        <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="10">
                            <Button Background="Transparent" BorderThickness="0" Click="OnSelectHomeWallpaperClick">
                                <Grid Padding="15">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="桌面壁纸设置" FontSize="16" Foreground="{DynamicResource SystemTextBrush}"/>
                                        <TextBlock x:Name="HomeWpStatusText" Text="点击从本地导入" FontSize="12" Foreground="#8E8E93"/>
                                    </StackPanel>
                                    <Border x:Name="HomeWpPreview" Width="50" Height="50" HorizontalAlignment="Right" Background="#EEE" CornerRadius="5" Overflow="Hidden">
                                        <TextBlock Text="🖼️" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20"/>
                                    </Border>
                                </Grid>
                            </Button>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Chat App Overlay -->
        <Border x:Name="ChatAppOverlay" Grid.Row="0" Grid.RowSpan="3" Visibility="Collapsed" Panel.ZIndex="200">
            <local:ChatApp x:Name="ChatAppControl"/>
        </Border>

        <!-- Dock (Placeholder) -->
        <Border x:Name="DockBorder" Grid.Row="2" Height="90" Margin="15,0,15,20" CornerRadius="30" Background="#4DFFFFFF">
            <UniformGrid x:Name="DockPanel" Columns="4">
            </UniformGrid>
        </Border>

        <!-- 拖拽浮层 - 在最顶层显示被拖拽的图标 -->
        <Canvas x:Name="DragOverlayCanvas" Grid.Row="0" Grid.RowSpan="3" Panel.ZIndex="9999"
                IsHitTestVisible="False" Visibility="Collapsed"/>

    </Grid>
</Window>