<UserControl x:Class="WangWangPhone.ChatApp"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#EDEDED">
    <Grid>
        <!-- Main View (Tabs) -->
        <Grid x:Name="MainView">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="56"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Background="#EDEDED">
                <TextBlock x:Name="HeaderTitle" Text="消息" FontSize="17" FontWeight="SemiBold" 
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="12,0">
                    <TextBlock Text="‹" FontSize="24" VerticalAlignment="Center" Cursor="Hand" 
                               MouseDown="OnCloseClick" Margin="0,0,8,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="12,0">
                    <TextBlock Text="🔍" FontSize="18" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock Text="⊕" FontSize="20" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
            <Border Grid.Row="0" BorderBrush="#DDD" BorderThickness="0,0,0,0.5" VerticalAlignment="Bottom"/>

            <!-- Content Area -->
            <ScrollViewer x:Name="ContentArea" Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ContentPanel"/>
            </ScrollViewer>

            <!-- Tab Bar -->
            <Border Grid.Row="2" Background="#F7F7F7" BorderBrush="#DDD" BorderThickness="0,0.5,0,0">
                <UniformGrid x:Name="TabBar" Columns="4"/>
            </Border>
        </Grid>

        <!-- Chat Detail View -->
        <Grid x:Name="ChatDetailView" Visibility="Collapsed" Background="#EDEDED">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <Grid Background="#EDEDED">
                <TextBlock x:Name="ChatDetailTitle" Text="" FontSize="17" FontWeight="SemiBold" 
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Text="‹" FontSize="24" HorizontalAlignment="Left" VerticalAlignment="Center" 
                           Margin="12,0" Cursor="Hand" MouseDown="OnChatDetailBack"/>
                <TextBlock Text="···" FontSize="20" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="12,0"/>
            </Grid>
            <Border Grid.Row="0" BorderBrush="#DDD" BorderThickness="0,0,0,0.5" VerticalAlignment="Bottom"/>

            <ScrollViewer x:Name="ChatMessagesScroll" Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ChatMessagesPanel" Margin="16,10"/>
            </ScrollViewer>

            <Grid Grid.Row="2" Background="#F7F7F7">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="🎙️" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="ChatInputBox" Grid.Column="1" VerticalAlignment="Center" 
                             BorderThickness="1" BorderBrush="#DDD" Padding="6,4" FontSize="14"/>
                    <TextBlock Grid.Column="2" Text="😊" FontSize="20" VerticalAlignment="Center" Margin="8,0"/>
                    <TextBlock Grid.Column="3" Text="⊕" FontSize="22" VerticalAlignment="Center" Margin="4,0" 
                               Cursor="Hand" MouseDown="OnSendMessage"/>
                </Grid>
            </Grid>
        </Grid>

        <!-- Service Page View -->
        <Grid x:Name="ServiceView" Visibility="Collapsed" Background="#EDEDED">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Background="#EDEDED">
                <TextBlock Text="服务" FontSize="17" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Text="‹" FontSize="24" HorizontalAlignment="Left" VerticalAlignment="Center" 
                           Margin="12,0" Cursor="Hand" MouseDown="OnServiceBack"/>
                <TextBlock Text="···" FontSize="20" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="12,0"/>
            </Grid>
            <Border Grid.Row="0" BorderBrush="#DDD" BorderThickness="0,0,0,0.5" VerticalAlignment="Bottom"/>

            <Grid Grid.Row="1">
                <Border Margin="16" CornerRadius="12" VerticalAlignment="Top">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#07C160" Offset="0"/>
                            <GradientStop Color="#06A954" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <UniformGrid Columns="2" Height="100">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="✓" FontSize="36" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="收付款" FontSize="14" Foreground="White" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="💳" FontSize="36" HorizontalAlignment="Center"/>
                            <TextBlock Text="钱包" FontSize="14" Foreground="White" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            <TextBlock Text="¥888.88" FontSize="12" Foreground="#B3FFFFFF" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </UniformGrid>
                </Border>

                <TextBlock Text="所有服务已关闭，前往设置 ›" FontSize="14" Foreground="#999" 
                           HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,40"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>